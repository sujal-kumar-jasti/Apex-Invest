<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="22dp">

        <!-- Top Section: Net Flow -->
        <FrameLayout
            android:id="@+id/iconWalletBg"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_purple_alpha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivWalletIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_wallet"
                app:tint="@color/brand_purple"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvNetFlowTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="NET CASH FLOW"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iconWalletBg"
            app:layout_constraintTop_toTopOf="@id/iconWalletBg"
            app:layout_constraintBottom_toTopOf="@id/tvNetFlowSubtitle"/>

        <TextView
            android:id="@+id/tvNetFlowSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Capital Flow In"
            android:textColor="@color/gray"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvNetFlowTitle"
            app:layout_constraintTop_toBottomOf="@id/tvNetFlowTitle"
            app:layout_constraintBottom_toBottomOf="@id/iconWalletBg"/>

        <TextView
            android:id="@+id/tvNetFlowValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="+$1,240.00"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:textColor="@color/trend_green"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconWalletBg"
            app:layout_constraintBottom_toBottomOf="@id/iconWalletBg"/>

        <!-- Middle Section: Pills -->
        <LinearLayout
            android:id="@+id/layoutPills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintTop_toBottomOf="@id/iconWalletBg">

            <!-- Invested Pill -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#26000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Invested"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/indicator_dot_green"
                        android:drawablePadding="6dp"/>
                    <TextView
                        android:id="@+id/tvTotalInvested"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="$4,500.00"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Liquidated Pill -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="18dp"
                app:strokeWidth="1dp"
                app:strokeColor="#26000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liquidated"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/indicator_dot_red"
                        android:drawablePadding="6dp"/>
                    <TextView
                        android:id="@+id/tvTotalLiquidated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="$3,260.00"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Bottom Section: Distribution Bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressDistribution"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="18dp"
            app:trackCornerRadius="5dp"
            app:indicatorColor="@color/trend_green"
            app:trackColor="@color/trend_red"
            tools:progress="65"
            app:layout_constraintTop_toBottomOf="@id/layoutPills"/>

        <TextView
            android:id="@+id/tvBuyRatio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="Buy 65%"
            android:textColor="@color/trend_green"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressDistribution"/>

        <TextView
            android:id="@+id/tvSellRatio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="Sell 35%"
            android:textColor="@color/trend_red"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressDistribution"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>