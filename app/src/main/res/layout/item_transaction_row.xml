<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    tools:strokeColor="#1A000000"
    tools:cardBackgroundColor="#ECEEF4">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <FrameLayout
            android:id="@+id/iconTrendBg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_rounded_14dp"
            tools:backgroundTint="#1A4CAF50"
            app:layout_constraintStart_toEndOf="@id/cbSelect"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivTrendIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                tools:src="@drawable/ic_trending_up"
                tools:tint="@color/trend_green"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvSymbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            tools:text="AAPL"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iconTrendBg"
            app:layout_constraintTop_toTopOf="@id/iconTrendBg"
            app:layout_constraintBottom_toTopOf="@id/tvUnitsDate"/>

        <TextView
            android:id="@+id/tvBuySellPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pill"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            tools:text="BUY"
            tools:textColor="@color/trend_green"
            tools:backgroundTint="#264CAF50"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvSymbol"
            app:layout_constraintTop_toTopOf="@id/tvSymbol"
            app:layout_constraintBottom_toBottomOf="@id/tvSymbol"/>

        <TextView
            android:id="@+id/tvUnitsDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="15 Units  •  Oct 24, 2023"
            android:textSize="12sp"
            android:textColor="@color/gray"
            app:layout_constraintStart_toStartOf="@id/tvSymbol"
            app:layout_constraintTop_toBottomOf="@id/tvSymbol"
            app:layout_constraintBottom_toBottomOf="@id/iconTrendBg"/>

        <TextView
            android:id="@+id/tvTotalValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="+$2,500.00"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:textColor="@color/trend_green"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconTrendBg"
            app:layout_constraintBottom_toTopOf="@id/tvPrice"/>

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="/@$166.66"
            android:textSize="12sp"
            android:textColor="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTotalValue"
            app:layout_constraintBottom_toBottomOf="@id/iconTrendBg"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>